---
import Base from '../layouts/Base.astro';
// Pagefind assets under /pagefind/ are generated by the `postbuild` step
// (`pagefind --site dist`). They exist in the built site, not in `astro dev`.
---

<Base title="Search" description="Search recipes.">
  <h1>Search</h1>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="search"></div>
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({ element: '#search', showSubResults: true });
      } else {
        document.getElementById('search').innerHTML =
          '<p class="muted">Search index is only available in the built site.</p>';
      }
    });
  </script>
</Base>
